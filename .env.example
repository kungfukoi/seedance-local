# Seedance Local
# Copy this file to .env, then replace the placeholder values with your own keys.

# Required for fal.ai video generation and Fal-hosted text node processing.
FAL_KEY=your_fal_key_here

# Required for the Nano Banana Pro image model.
GOOGLE_API_KEY=your_google_api_key_here

# Text node processing through fal.ai.
TEXT_LLM_PROVIDER=fal
FAL_TEXT_MODEL=openai/gpt-4o
FAL_VISION_TEXT_MODEL=openai/gpt-4o
FAL_VIDEO_TEXT_MODEL=google/gemini-2.5-flash

# Local server port.
PORT=3333

# Optional: use OpenAI directly for text nodes or OpenAI Image 2.
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_TEXT_API_KEY=your_openai_text_key_here
# OPENAI_IMAGE_API_KEY=your_openai_image_key_here
# OPENAI_TEXT_MODEL=gpt-5.5
# OPENAI_IMAGE_2_QUALITY=medium

# Optional: cost estimate overrides for the Stats tab.
# SEEDANCE_STANDARD_COST_PER_SECOND=0.014
# SEEDANCE_FAST_COST_PER_SECOND=0.0112
# NANO_BANANA_IMAGE_COST_1K_2K=0.134
# NANO_BANANA_IMAGE_COST_4K=0.24
# OPENAI_IMAGE_2_MEDIUM_COST=0.053
# FAL_TEXT_REQUEST_COST=0.001
# FAL_VISION_TEXT_UNIT_COST=0.01
# FAL_VIDEO_TEXT_UNIT_COST=0.01
